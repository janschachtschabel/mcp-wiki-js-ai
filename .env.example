# =============================================================================
# Wiki.js + MCP Appliance — Umgebungsvariablen (cp .env.example .env)
# =============================================================================

# Öffentliche Domain des Stacks (Wiki + MCP auf EINER Domain → Ein-Klick-SSO).
# Für lokale Tests: localhost
DOMAIN=wiki.example.org

# Optional: abweichende öffentliche Basis-URL (Default: https://$DOMAIN).
# PUBLIC_BASE_URL=

# Postgres-Passwort für die Wiki.js-Datenbank.
# Erzeugen:  openssl rand -base64 24
POSTGRES_PASSWORD=

# Schaltet OAuth ein (Login = Wiki.js-Login; Sessions verschlüsselt in /data).
# Erzeugen:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MCP_SESSION_SECRET=

# Seiten mit diesen Tags sind für KI-Agenten unsichtbar & unantastbar
# (kommasepariert, case-insensitive; leer = Feature aus).
WIKIJS_BLOCKED_TAGS=kein-ki

# --- Selten nötig -----------------------------------------------------------
# Wiki.js-DB-Pool (Knex; via deploy/wiki/config.yml). 20 direkte Verbindungen
# sind für Postgres (max_connections=100) unkritisch — PgBouncer ist bei einer
# einzelnen Wiki-Instanz nicht nötig.
# WIKIJS_DB_POOL_MIN=2
# WIKIJS_DB_POOL_MAX=20
# Parallele Upstream-Requests des MCP-Servers (unter DB_POOL_MAX halten).
# WIKIJS_MAX_CONCURRENCY=12
# Agenten-Schutzrolle für OAuth-Sessions (config/roles.json im MCP-Server).
# WIKIJS_OAUTH_ROLE=wiki
# Globales Rechte-Ceiling des MCP-Servers (bei OAuth: full lassen).
# WIKIJS_PERMISSION_PRESET=full
# Audit-Log (Tool, Nutzer-Label, Ergebnis) — an/aus.
# WIKIJS_AUDIT=true
# Fertiges Image statt lokalem Build (z. B. aus GHCR):
# MCP_IMAGE=ghcr.io/<org>/<repo>:main
