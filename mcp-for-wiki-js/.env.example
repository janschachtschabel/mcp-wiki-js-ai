# =============================================================================
# mcp-wikijs-mv — environment configuration
# =============================================================================
# All of these are OPTIONAL on the HTTP/Vercel transport when clients send their
# own credentials per request via headers (see README "Multi-user / BYOK").
# They are REQUIRED for the local stdio transport (single user).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# OAuth mode (RECOMMENDED for self-hosted/Docker): "the wiki login IS the login"
# -----------------------------------------------------------------------------
# Setting MCP_SESSION_SECRET turns on OAuth 2.1: clients connect with ONE clean
# URL (https://<host>/mcp, no secrets in it), the browser-based authorize step
# is the normal Wiki.js login (one click when already logged in on the same
# domain), and every session acts with exactly that USER's wiki permissions.
# Sessions live encrypted in a small sqlite DB under MCP_DATA_DIR.
# NOT available on Vercel/serverless (no persistent disk) — there keep using
# WIKIJS_PROFILES handles below.
#
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MCP_SESSION_SECRET=
# Where the session DB lives (default ./data; the Docker image uses /data).
MCP_DATA_DIR=
# Agent-safety overlay applied to OAuth sessions (role name from config/roles.json).
# Default "wiki": read/write allowed, delete + admin actions gated behind confirm.
# ACCESS CONTROL itself comes from the wiki user's own groups/page-rules.
WIKIJS_OAUTH_ROLE=
# NOTE: with OAuth, set the ceiling to "full" — the effective rights come from
# Wiki.js per user, the ceiling must not hide tools the wiki would allow:
#   WIKIJS_PERMISSION_PRESET=full

# -----------------------------------------------------------------------------
# Tag guardrail: hide pages from AI agents by tag (e.g. "kein-ki")
# -----------------------------------------------------------------------------
# Comma-separated, case-insensitive. Closes Wiki.js' tag-rule leak (its list/
# single resolvers don't enforce TAG deny-rules) at the MCP layer: matching
# pages are hidden from search/get/list/history/version and refused for
# write/move/delete. Path-based Wiki.js deny-rules remain the hard guarantee.
# Empty = off (no extra upstream queries).
WIKIJS_BLOCKED_TAGS=

# Base URL of your Wiki.js instance (no trailing /graphql).
#   e.g. https://wiki.example.org
WIKIJS_URL=

# Wiki.js API key (JWT) used as `Authorization: Bearer <token>`.
# Create one in Wiki.js: Administration → API → enable + create key.
WIKIJS_TOKEN=

# -----------------------------------------------------------------------------
# Permission roles (graduated rights ladder)
# -----------------------------------------------------------------------------
# Roles are defined & fully editable in config/roles.json. Default ladder:
#   leser → kommentator → autor → redakteur → moderator/betreuer → admin → systemadmin
#   (legacy aliases: readonly, safe, editor, maintainer, full)
#
# WIKIJS_PERMISSION_PRESET = the global CEILING: the MAX capability anyone can have
# and what is visible in tools/list. Set it to your MOST-privileged role (per-person
# roles in WIKIJS_PROFILES then narrow down from there).
WIKIJS_PERMISSION_PRESET=safe

# Optional: override the ROLE definitions at runtime (no rebuild), same JSON shape as
# config/roles.json. Partial roles only override the categories/tools you list.
#   WIKIJS_ROLES={"roles":{"redakteur":{"extends":"autor","categories":{"delete":"block"}}}}
WIKIJS_ROLES=

# Optional JSON override on top of the preset. Per-category and per-tool.
# Modes: "allow" | "confirm" | "block".
# Example: allow page deletes without confirm, but block user management:
#   WIKIJS_POLICY={"categories":{"delete":"allow","manage_users":"block"},"tools":{"wiki_graphql":"block"}}
WIKIJS_POLICY=

# Show blocked tools in tools/list as disabled stubs (they still refuse to run).
# Default false = blocked tools are hidden entirely.
WIKIJS_SHOW_BLOCKED=false

# -----------------------------------------------------------------------------
# Multi-user: assign a ROLE per person (RECOMMENDED)
# -----------------------------------------------------------------------------
# The wiki URL is set ONCE above (WIKIJS_URL) — usually all users share one wiki.
# Each profile maps a SECRET handle (the map KEY) -> { label, token, role }. The
# client only ever sends the handle; the real key NEVER leaves the server and is
# never seen by the LLM provider.
#
# Connect (the handle IS the token):
#   URL param : https://<deploy>/mcp?token=<handle>
#   header    : X-Wikijs-Token: <handle>   (or  Authorization: Bearer <handle>)
#
#   - map KEY = SECRET handle. MUST be high-entropy & UNGUESSABLE (NOT a name) —
#               else anyone could use someone else's handle. Generate with:
#                 node scripts/gen-profile.mjs "Alice:leser" "Bob:redakteur"
#   - label   = non-secret name (shown in connection_status; the secret is never echoed)
#   - token   = the real (SCOPED) Wiki.js API key
#   - role    = a role name from config/roles.json (leser, autor, redakteur, admin, …)
#   - url     = OPTIONAL per-profile override (rarely needed; defaults to WIKIJS_URL)
#   - policy  = OPTIONAL inline fine-tuning on top of the role
# Example (two users, one wiki, different roles):
#   WIKIJS_PROFILES={"wzp_…SECRET-A":{"label":"Alice","token":"KEY_A","role":"leser"},"wzp_…SECRET-B":{"label":"Bob","token":"KEY_B","role":"redakteur"}}
WIKIJS_PROFILES=

# Simpler legacy form (alias -> token string only; url/policy from env/headers).
# Superseded by WIKIJS_PROFILES; kept for backward compatibility.
# JSON object: { "<alias>": "<realToken>", ... }
WIKIJS_KEY_MAP=

# -----------------------------------------------------------------------------
# Misc (optional)
# -----------------------------------------------------------------------------
# Per-request GraphQL timeout in ms (default 30000).
WIKIJS_TIMEOUT_MS=
# Overload protection: max concurrent upstream GraphQL requests this server fires at Wiki.js
# (default 8). Excess requests queue briefly, then are shed with a "busy" error instead of
# piling into a 60s DB-pool-acquire hang. Keep (expected Vercel instances × this value) BELOW
# your Wiki.js sustained ceiling (≈ Knex pool.max minus headroom for browsing / other apps).
WIKIJS_MAX_CONCURRENCY=

# Retry count for CONNECTION-level failures only (DNS/TCP/TLS, "fetch failed") — safe even for
# mutations since the request never reached the server. Default 2. Timeouts and GraphQL errors
# are never retried.
WIKIJS_RETRIES=

# Audit log of write/delete/admin actions (tool, category, profile LABEL, outcome, ms) to the
# server logs. On by default; set "false" to disable. Never logs secrets or the real key.
WIKIJS_AUDIT=

# Set "true" to log MCP request details (HTTP transport).
WIKIJS_MCP_VERBOSE=
# Override the base URL advertised in /.well-known/mcp.json (else derived from headers).
PUBLIC_BASE_URL=
